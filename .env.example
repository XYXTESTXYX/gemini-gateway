# ────────────────────────────────────────────
#  YOUR SECRET KEY — share this with no one
#  This is what YOU use to call your gateway
# ────────────────────────────────────────────
MY_API_KEY=my-super-secret-key-change-this

# ────────────────────────────────────────────
#  GEMINI KEYS — add as many as you want
#  Format: GEMINI_KEY_1, GEMINI_KEY_2, etc.
# ────────────────────────────────────────────
GEMINI_KEY_1=AIzaSy...your_first_key
GEMINI_KEY_2=AIzaSy...your_second_key
GEMINI_KEY_3=AIzaSy...your_third_key
GEMINI_KEY_4=AIzaSy...your_fourth_key
GEMINI_KEY_5=AIzaSy...your_fifth_key
# GEMINI_KEY_6=...
# GEMINI_KEY_7=...
# GEMINI_KEY_8=...
# GEMINI_KEY_9=...
# GEMINI_KEY_10=...

# ────────────────────────────────────────────
#  SETTINGS
# ────────────────────────────────────────────
RPM_PER_KEY=15
PORT=3000
